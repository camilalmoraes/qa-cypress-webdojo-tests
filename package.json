{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "serve -s dist -p 3000",
    "test": "cypress run",
    "report:merge": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
    "report:generate": "npx marge cypress/reports/report.json -f report -o cypress/reports",
    "test:report": "npm run test && npm run report:merge && npm run report:generate"
  },
  "dependencies": {
    "serve": "^14.2.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "cypress": "^15.12.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}